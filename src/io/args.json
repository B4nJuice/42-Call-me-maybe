{
	"--input": {
		"alias" : "-i",
		"default": "./data/input/function_calling_tests.json",
		"type": "string",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--function_definitions": {
		"alias" : "-fd",
		"default": "./data/input/function_definitions.json",
		"type": "string",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--output": {
		"alias" : "-o",
		"default": "./data/output/function_calls.json",
		"type": "string",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--model": {
		"alias" : "-m",
		"default": "Qwen/Qwen3-0.6B",
		"type": "string",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--device": {
		"alias" : "-dv",
		"default": "cpu",
		"type": "string",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--confidence": {
		"alias" : "-c",
		"default": 22,
		"type": "integer",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--max-token": {
		"alias" : "-mt",
		"default": 60,
		"type": "integer",
		"required": 0,
		"action": "store",
		"nargs": 1
	},
	"--debug": {
		"alias": "-d",
    	"default": false,
    	"type": "boolean",
